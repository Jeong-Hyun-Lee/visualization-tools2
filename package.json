{
  "name": "ge-vernova",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:electron": "ng build --base-href ./ --deploy-url ./",
    "build:electron:dev": "ng build --configuration development --base-href ./ --deploy-url ./",
    "electron": "npm run build:electron && electron .",
    "electron:dev": "npm run build:electron:dev && electron .",
    "electron:pack": "npm run build:electron && electron-builder --dir --publish never",
    "electron:dist": "npm run build:electron && electron-builder --win nsis --publish never",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test"
  },
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@angular/animations": "21.2.8",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "21.2.8",
    "@angular/compiler": "21.2.8",
    "@angular/core": "21.2.8",
    "@angular/forms": "21.2.8",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "21.2.8",
    "@angular/platform-browser-dynamic": "21.2.8",
    "@angular/router": "21.2.8",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "ng-diagram": "^1.1.2",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.7",
    "@analogjs/vitest-angular": "^2.4.7",
    "@angular-devkit/build-angular": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.8",
    "@types/lodash-es": "^4.17.12",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^22.18.9",
    "electron": "^41.1.0",
    "electron-builder": "^23.6.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.ge.vernova.nodeeditor",
    "productName": "GE Vernova Node Editor",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "nsis": {
      "perMachine": true,
      "allowElevation": true,
      "include": "build/installer.nsh"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
